{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 220,
  "title": "EFT Spending Accountability, 2019–2024",
  "data": {
    "sequence": {
      "start": 0,
      "stop": 100,
      "step": 1,
      "as": "square_id"
    }
  },
  "transform": [
    {
      "calculate": "datum.square_id % 20",
      "as": "col"
    },
    {
      "calculate": "floor(datum.square_id / 20)",
      "as": "row"
    },
    {
      "calculate": "datum.square_id < 95 ? 'No public record' : datum.square_id < 97 ? 'Johor' : datum.square_id < 98 ? 'Sabah' : datum.square_id < 99 ? 'Pahang' : 'Kelantan'",
      "as": "category"
    },
    {
      "calculate": "datum.category === 'No public record' ? 'RM 492M, about 95% of total funding' : datum.category === 'Johor' ? 'RM 12M documented' : datum.category === 'Sabah' ? 'RM 6.8M documented' : datum.category === 'Pahang' ? 'RM 4M documented' : 'RM 2.2M documented'",
      "as": "amount_label"
    }
  ],
  "mark": {
    "type": "rect",
    "stroke": "white",
    "strokeWidth": 1.2,
    "cornerRadius": 2
  },
  "encoding": {
    "x": {
      "field": "col",
      "type": "ordinal",
      "axis": null,
      "scale": {
        "paddingInner": 0,
        "paddingOuter": 0
      }
    },
    "y": {
      "field": "row",
      "type": "ordinal",
      "axis": null,
      "scale": {
        "paddingInner": 0,
        "paddingOuter": 0
      }
    },
    "color": {
      "field": "category",
      "type": "nominal",
      "title": "Category",
      "scale": {
        "domain": [
          "No public record",
          "Johor",
          "Sabah",
          "Pahang",
          "Kelantan"
        ],
        "range": [
          "#E8E8E8",
          "#6A51A3",
          "#5AB4AC",
          "#D8B365",
          "#9E9AC8"
        ]
      },
      "legend": {
        "orient": "bottom",
        "columns": 3,
        "titleFontSize": 12,
        "labelFontSize": 11,
        "symbolType": "square"
      }
    },
    "tooltip": [
      {
        "field": "category",
        "type": "nominal",
        "title": "Category"
      },
      {
        "field": "amount_label",
        "type": "nominal",
        "title": "Amount"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": false
    }
  }
}