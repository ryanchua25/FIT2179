{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "title": "Malaysia Tree Cover Loss by Driver",
  "data": {"url": "https://raw.githubusercontent.com/ryanchua25/FIT2179/main/data/tree_cover_loss_drivers.csv"},
  "mark": {
    "type": "area",
    "interpolate": "monotone"
  },
  "params": [
    {
      "name": "driver",
      "select": {
        "type": "point",
        "fields": ["loss drivers"]
      },
      "bind": "legend"
    }
  ],
"encoding": {
  "x": {
    "field": "year",
    "type": "ordinal",
    "title": "Year"
  },
  "y": {
    "aggregate": "sum",
    "field": "tree_cover_loss_ha",
    "type": "quantitative",
    "title": "Tree Cover Lost (hectares)",
    "stack": true
  },
  "color": {
    "field": "loss drivers",
    "type": "nominal",
    "title": "Driver",
    "scale": {
      "scheme": "tableau10"
    },
    "sort": {
      "field": "tree_cover_loss_ha",
      "op": "sum",
      "order": "ascending"
    }
  },
  "order": {
    "aggregate": "sum",
    "field": "tree_cover_loss_ha",
    "type": "quantitative",
    "sort": "descending"
  },
  "opacity": {
    "condition": {
      "param": "driver",
      "value": 1
    },
    "value": 0.18
  },
    "tooltip": [
      {"field": "year", "type": "ordinal","title": "Year"},
      {"field": "loss drivers","type": "nominal","title": "Driver"},
      {"field": "tree_cover_loss_ha","type": "quantitative","title": "Tree Cover Lost (hectares)"}
    ]
  }
}