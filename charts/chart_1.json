{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "title": "Yearly Tree Cover Loss In Malaysia",
  "data": {"url": "https://raw.githubusercontent.com/ryanchua25/FIT2179/main/data/tree_cover_loss.csv"},
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": true,
        "color": "black",
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": "Year"
        },
        "y": {
          "field": "Tree Cover Loss",
          "type": "quantitative",
          "title": "Tree Cover Lost (hectares)"
        },
        "tooltip": [
          { "field": "Year", "type": "ordinal", "title": "Year" },
          { "field": "Tree Cover Loss", "type": "quantitative", "title": "Hectares Lost"}
        ]
      }
    },
    {
      "data": { "values": [{ "Year": "2019" }] },
      "mark": {
        "type": "rule",
        "color": "blue",
        "strokeDash": [4, 4],
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": { "field": "Year", "type": "ordinal" }
      }
    },
    {
      "data": { "values": [{ "Year": "2019", "label": "EFT introduced" }] },
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 6,
        "dy": -120,
        "color": "black",
        "fontSize": 11,
        "fontStyle": "italic"
      },
      "encoding": {
        "x": { "field": "Year", "type": "ordinal" },
        "text": { "field": "label" }
      }
    }
  ]
}