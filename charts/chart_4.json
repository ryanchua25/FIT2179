{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 600,
  "height": 400,
  "title": "Tree Cover Loss by Malaysian State, Normalised by Land Area",
  "projection": {
    "type": "mercator"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/ryanchua25/FIT2179/main/data/Malaysia-state.json",
    "format": {
      "type": "topojson",
      "feature": "geoBoundaries-MYS-ADM1"
    }
  },
  "transform": [
    {
      "lookup": "properties.shapeName",
      "from": {
        "data": {
          "url": "https://raw.githubusercontent.com/ryanchua25/FIT2179/main/data/tree_cover_loss_by_state.csv"
        },
        "key": "State",
        "fields": ["total_loss_ha", "land_area_ha", "loss_pct_land"]
      }
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "black",
    "strokeWidth": 0.6
  },
  "encoding": {
    "color": {
      "field": "loss_pct_land",
      "type": "quantitative",
      "title": "Loss (% of land area)",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "properties.shapeName",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "total_loss_ha",
        "type": "quantitative",
        "title": "Total Loss (ha)",
        "format": ",.0f"
      },
      {
        "field": "land_area_ha",
        "type": "quantitative",
        "title": "Land Area (ha)",
        "format": ",.0f"
      },
      {
        "field": "loss_pct_land",
        "type": "quantitative",
        "title": "Loss (% of land area)",
        "format": ".1f"
      }
    ]
  }
}