{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "title": "Malaysia EFT Conservation Budget",
  "data": {
    "url": "https://raw.githubusercontent.com/ryanchua25/FIT2179/main/data/EFT_year.csv"
  },
  "layer": [
    {
      "mark": "line",
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year"
        },
        "y": {
          "field": "allocation_rm_million",
          "type": "quantitative",
          "title": "Allocation (RM million)",
          "scale": {"domain": [0, 2000]}
        },
        "color": {"value": "black"},
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "allocation_rm_million", "type": "quantitative", "title": "Allocated (RM million)"}
        ]
      }
    },
    {
      "data": {"values": [{"target": 1000}]},
      "mark": {
        "type": "rule",
        "color": "black",
        "strokeDash": [4, 4],
        "strokeWidth": 2
      },
      "encoding": {
        "y": {"field": "target", "type": "quantitative"}
      }
    },
    {
      "data": {"values": [{"year": "2019", "label": "Conservationist target: RM 1 billion", "target": 1000}]},
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 4,
        "dy": -8,
        "color": "black",
        "fontSize": 11,
        "fontStyle": "italic"
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "target", "type": "quantitative"},
        "text": {"field": "label"}
      }
    }
  ]
}